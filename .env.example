# Environment variables for mlb_service
# Copy this file to mlb_service/.env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mlb_db

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MLB Stats API
MLB_STATS_API_BASE_URL=https://statsapi.mlb.com/api/v1/
MLB_STATS_API_TIMEOUT=10

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=
